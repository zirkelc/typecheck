{
  "files.associations": {
    "turbo.json": "jsonc"
  },
  // FORMATTER
  // https://oxc.rs/docs/guide/usage/formatter.html
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
